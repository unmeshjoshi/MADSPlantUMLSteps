@startuml
!theme plain
skinparam componentStyle rectangle
skinparam nodesep 50

node "Database Cluster" {
    component "Node 1" as N1 {
        rectangle "Partition 1\n(Keys A-H)" as P1
    }
    
    component "Node 2" as N2 {
        rectangle "Partition 2\n(Keys I-Q)" as P2
    }
    
    component "Node 3" as N3 {
        rectangle "Partition 3\n(Keys R-Z)" as P3
    }
    
    N1 -[hidden]right- N2
    N2 -[hidden]right- N3
}
@enduml

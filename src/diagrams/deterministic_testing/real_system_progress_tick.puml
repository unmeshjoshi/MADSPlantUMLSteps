@startuml
!include ../../style.puml

box "CPU Subsystem" #E6F3FF
participant "CPU Clock" as CPUClock
participant "CPU" as CPU
participant "Thread" as Thread
end box

box "NIC Subsystem" #e6f3ffff
participant "NIC Controller" as NICClock
participant "NIC" as NIC
end box

box "Disk Subsystem" #e6faffff
participant "Disk Controller" as DiskClock
participant "Disk" as Disk
end box

' [step1 {"name":"CPU Issues Work"}]
CPUClock -> CPU : tick
CPU -> Thread : advance execution
Thread -> Thread : handle quorum write

CPUClock -> CPU : tick
CPU -> Thread : advance execution
Thread -> NIC : issue replication send
' [/step1]

' [step2 {"name":"NIC Progress", "newPage":"true"}]
NICClock -> NIC : tick
NIC -> NIC : deliver network message
' [/step2]

' [step3 {"name":"Disk Progress", "newPage":"true"}]
CPUClock -> CPU : tick
CPU -> Thread : advance execution
Thread -> Disk : issue storage write

DiskClock -> Disk : tick
Disk -> Disk : persist data
' [/step3]

' [step4 {"name":"CPU Observes Results"}]
NICClock -> NIC : tick
NIC --> Thread : replication ack ready

CPUClock -> CPU : tick
CPU -> Thread : advance execution
Thread -> Thread : mark quorum reached
' [/step4]

note across #E6F3FF
Different subsystems advance through their own internal ticks,
and software observes the resulting interleaving.
end note

@enduml
